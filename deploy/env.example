# Copy to /etc/comprehend/env (chmod 600, owned by the comprehend service user).
# Generate secrets with:  /opt/comprehend/.venv/bin/comprehend gen-secret
# Generate the password hash with:  /opt/comprehend/.venv/bin/comprehend hash-password

# Production mode: requires OWNER_SECRET + SESSION_KEY to be set (no dev fallbacks).
COMPREHEND_DEV=0

# Public origin (used to build the connector links handed to people).
COMPREHEND_BASE_URL=https://comprehend.fdosmith.dev

# Bind (Caddy proxies to this). Keep on localhost.
COMPREHEND_HOST=127.0.0.1
COMPREHEND_PORT=8793

# SQLite location (the systemd StateDirectory provides /var/lib/comprehend).
COMPREHEND_DB_PATH=/var/lib/comprehend/comprehend.db

# Built SPA assets served by the app.
COMPREHEND_WEB_DIST=/opt/comprehend/web/dist

# The secret in the owner connector URL: https://comprehend.fdosmith.dev/owner/<secret>/mcp
COMPREHEND_OWNER_SECRET=replace-with-gen-secret-output

# HMAC key for signing dashboard session cookies.
COMPREHEND_SESSION_KEY=replace-with-gen-secret-output

# scrypt hash of the dashboard admin password (from `comprehend hash-password`).
COMPREHEND_ADMIN_PASSWORD_HASH=replace-with-hash-password-output
